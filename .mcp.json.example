{
  "mcpServers": {
    "origin-ui": {
      "type": "stdio",
      "command": "npx",
      "args": ["--yes", "github:kelvinchng/origin-ui-mcp"],
      "env": {}
    },
    "shadcn": {
      "type": "http",
      "url": "https://www.shadcn.io/api/mcp"
    },
    "icons8mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["mcp-remote", "https://mcp.icons8.com/mcp/"],
      "env": {}
    },
    "ssh-mcp-personal-vps": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@fangjunjie/ssh-mcp-server",
        "--host", "YOUR_VPS_IP",
        "--port", "22",
        "--username", "root",
        "--privateKey", "~/.ssh/id_ed25519",
        "--passphrase", "YOUR_PASSPHRASE"
      ]
    }
  }
}
